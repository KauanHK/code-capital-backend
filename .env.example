# Para executar a API dentro do Docker Compose, use host "postgres".
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/sw
API_TITLE=SW Backend API
API_VERSION=0.1.0

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Token - MUDE ISSO EM PRODUÇÃO! Use um token seguro e único
# Este token permite acessar dados de qualquer usuário
# Exemplo: admin-token-unique-and-secure-change-me
ADMIN_TOKEN=admin-token-change-in-production

# Evolution API - WhatsApp Integration
EVOLUTION_ENCRYPTION_KEY=evol_secret_key_12345
EVOLUTION_API_KEY=sk_evolution_default_key

